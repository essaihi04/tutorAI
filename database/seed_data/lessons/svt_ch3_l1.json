{
  "title_fr": "Utilisation des matieres organiques et inorganiques",
  "title_ar": "استعمال المواد العضوية وغير العضوية",
  "lesson_type": "theory",
  "duration_minutes": 140,
  "learning_objectives": [
    "Identifier les formes d'utilisation des matieres organiques et inorganiques dans la vie quotidienne",
    "Analyser l'impact des ordures menageres et des rejets polluants sur les milieux naturels",
    "Expliquer les mecanismes de pollution de l'air, de l'eau et du sol",
    "Evaluer les risques et les usages des matieres radioactives et de l'energie nucleaire"
  ],
  "content": {
    "micro_enseignements": [
      { "id": "svt_ch3_intro_utilisation_matieres", "title": "1. Introduction : utilisation des matières organiques et inorganiques", "type": "introduction", "resources": ["situation_probleme_dechets_menagers"] },
      { "id": "svt_ch3_ordures_menageres_nature", "title": "2. Nature et classification des ordures ménagères", "type": "concept", "resources": ["tableau_types_dechets"] },
      { "id": "svt_ch3_ordures_menageres_impacts", "title": "3. Impacts des ordures ménagères sur l'environnement", "type": "application", "resources": ["etude_decharge_pollution"] },
      { "id": "svt_ch3_pollution_air", "title": "4. Pollution de l'air : smog, pluies acides et effet de serre", "type": "concept", "resources": ["schema_pollution_atmospherique"] },
      { "id": "svt_ch3_pollution_eau_sol", "title": "5. Pollution de l'eau et du sol", "type": "concept", "resources": ["cas_eutrophisation_pesticides"] },
      { "id": "svt_ch3_traitement_reduction_dechets", "title": "6. Traitement, tri et reduction des dechets", "type": "processus", "resources": ["schema_recyclage_valorisation"] },
      { "id": "svt_ch3_matieres_radioactives", "title": "7. Matières radioactives : origines, usages et risques", "type": "concept", "resources": ["schema_radioactivite_usages"] },
      { "id": "svt_ch3_energie_nucleaire", "title": "8. Energie nucleaire, dechets radioactifs et prevention", "type": "application", "resources": ["centrale_nucleaire_schema"] },
      { "id": "svt_ch3_energies_renouvelables", "title": "9. Energies renouvelables et developpement durable", "type": "synthese", "resources": ["comparatif_energies_renouvelables"] },
      { "id": "svt_ch3_synthese", "title": "10. Synthèse et évaluation du chapitre", "type": "evaluation", "resources": ["quiz_pollution_matieres"] }
    ],
    "phases": {
      "activation": { "duration_minutes": 10, "focus_micro_enseignements": ["svt_ch3_intro_utilisation_matieres"] },
      "exploration": { "duration_minutes": 35, "focus_micro_enseignements": ["svt_ch3_ordures_menageres_nature", "svt_ch3_ordures_menageres_impacts", "svt_ch3_pollution_air"] },
      "explanation": { "duration_minutes": 45, "focus_micro_enseignements": ["svt_ch3_pollution_eau_sol", "svt_ch3_traitement_reduction_dechets", "svt_ch3_matieres_radioactives"] },
      "application": { "duration_minutes": 35, "focus_micro_enseignements": ["svt_ch3_energie_nucleaire", "svt_ch3_energies_renouvelables"] },
      "consolidation": { "duration_minutes": 15, "focus_micro_enseignements": ["svt_ch3_synthese"] }
    }
  },
