{
  "title_fr": "L'immunologie",
  "title_ar": "علم المناعة",
  "lesson_type": "theory",
  "duration_minutes": 140,
  "learning_objectives": [
    "Distinguer le soi du non-soi",
    "Décrire l'immunité innée et l'immunité adaptative",
    "Expliquer la coopération des cellules immunitaires",
    "Analyser quelques dysfonctionnements et aides du système immunitaire"
  ],
  "content": {
    "micro_enseignements": [
      { "id": "svt_ch5_intro_immunologie", "title": "1. Introduction et notions du soi / non-soi", "type": "introduction", "resources": ["situation_greffe_agent_pathogene"] },
      { "id": "svt_ch5_barrieres", "title": "2. Barrières naturelles et première ligne de défense", "type": "concept", "resources": ["schema_barrieres_naturelles"] },
      { "id": "svt_ch5_inflammation", "title": "3. Réaction inflammatoire et phagocytose", "type": "processus", "resources": ["animation_inflammation_phagocytose"] },
      { "id": "svt_ch5_antigene_anticorps", "title": "4. Antigène, anticorps et spécificité immunitaire", "type": "concept", "resources": ["schema_complexe_antigene_anticorps"] },
      { "id": "svt_ch5_immunite_humorale", "title": "5. Immunité humorale : rôle des lymphocytes B", "type": "processus", "resources": ["schema_lb_plasmocytes"] },
      { "id": "svt_ch5_immunite_cellulaire", "title": "6. Immunité cellulaire : rôle des lymphocytes T", "type": "processus", "resources": ["schema_lt_cytotoxiques"] },
      { "id": "svt_ch5_cooperation", "title": "7. Coopération cellulaire et mémoire immunitaire", "type": "synthese", "resources": ["tableau_cooperation_immunitaire"] },
      { "id": "svt_ch5_vaccination_serotherapie", "title": "8. Vaccination, sérothérapie et prévention", "type": "application", "resources": ["comparaison_vaccination_serotherapie"] },
      { "id": "svt_ch5_allergie", "title": "9. Allergie et hypersensibilité", "type": "application", "resources": ["cas_allergie"] },
      { "id": "svt_ch5_sida", "title": "10. SIDA et déficience immunitaire", "type": "application", "resources": ["schema_vih_lymphocyte_t4"] },
      { "id": "svt_ch5_synthese", "title": "11. Synthèse et évaluation", "type": "evaluation", "resources": ["quiz_immunologie"] }
    ],
    "phases": {
      "activation": { "duration_minutes": 10, "focus_micro_enseignements": ["svt_ch5_intro_immunologie"] },
