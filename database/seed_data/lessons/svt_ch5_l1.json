      "explanation": { "duration_minutes": 50, "focus_micro_enseignements": ["svt_ch5_immunite_humorale", "svt_ch5_immunite_cellulaire", "svt_ch5_cooperation"] },
      "application": { "duration_minutes": 30, "focus_micro_enseignements": ["svt_ch5_vaccination_serotherapie", "svt_ch5_allergie", "svt_ch5_sida"] },
      "consolidation": { "duration_minutes": 15, "focus_micro_enseignements": ["svt_ch5_synthese"] }
    }
